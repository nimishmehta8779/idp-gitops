# AWS credentials for Crossplane EKS provisioning
# Required: IAM user or role with EKS, EC2, IAM permissions

# --- Option 1: Single account simulation (use same credentials for both envs) ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
# Optional: only needed for temporary session credentials (assumed roles, SSO)
# AWS_SESSION_TOKEN=

# --- Option 2: Multi-account mode (use different credentials per env) ---
# AWS_ACCESS_KEY_ID_DEV=AKIA...
# AWS_SECRET_ACCESS_KEY_DEV=...
# AWS_DEFAULT_REGION_DEV=us-east-1
# AWS_SESSION_TOKEN_DEV=

# AWS_ACCESS_KEY_ID_STAGING=AKIA...
# AWS_SECRET_ACCESS_KEY_STAGING=...
# AWS_DEFAULT_REGION_STAGING=us-east-1
# AWS_SESSION_TOKEN_STAGING=
